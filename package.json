{
  "name": "react-native-modul-comu-osam",
  "version": "0.3.0",
  "description": "React Native bridge for Barcelona City Council's OSAM common module — version control, native rating prompt, device/app info, language-change and first-time/update events, FCM topic subscribe/unsubscribe, and FCM token retrieval. Firebase-backed default wrappers included; swappable at runtime.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "!ios/build",
    "!android/build",
    "!android/.gradle",
    "!**/__tests__",
    "!**/.DS_Store",
    "react-native-modul-comu-osam.podspec",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "build": "bob build",
    "prepare": "bob build",
    "clean": "del-cli lib"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "barcelona",
    "osam",
    "modul-comu-osam",
    "version-control",
    "rating",
    "fcm",
    "firebase-messaging",
    "push-notifications"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junjielyu13/react-native-modul-comu-osam.git"
  },
  "homepage": "https://github.com/junjielyu13/react-native-modul-comu-osam#readme",
  "bugs": {
    "url": "https://github.com/junjielyu13/react-native-modul-comu-osam/issues"
  },
  "author": "junjie li <jfjunjieli@gmail.com>",
  "contributors": [
    "Altech <altech@altech.es>"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "del-cli": "^5.1.0",
    "react": "19.0.0",
    "react-native": "0.79.1",
    "react-native-builder-bob": "^0.36.0",
    "typescript": "5.0.4"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
